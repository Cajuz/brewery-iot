# ── WiFi (ESP32) ───────────────────────────────────────
WIFI_SSID=NOME_DO_HOTSPOT
WIFI_PASSWORD=SENHA_HOTSPOT

# ── MQTT ───────────────────────────────────────────────
MQTT_BROKER_HOST=192.168.137.1
MQTT_BROKER_PORT=1883
MQTT_TOPIC_SENSORS=brewery/sensors
MQTT_TOPIC_HEALTH=brewery/health

# ── MongoDB ────────────────────────────────────────────
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=brewery

# ── Grafana ────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
GF_INSTALL_PLUGINS=grafana-mongodb-datasource

# ── Node-RED ───────────────────────────────────────────
NODE_RED_PORT=1880

# ── Processo ───────────────────────────────────────────
VOLUME_META_LITROS=50
SENSOR_TIMEOUT_SECONDS=120
TEMP_MIN=15
TEMP_MAX=22
